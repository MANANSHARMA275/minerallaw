# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=dev-secret-change-in-production

# Database (Railway PostgreSQL — fill in before deploy)
DATABASE_URL=sqlite:///minerallaw.db

# Redis (Upstash — fill in Phase 1)
REDIS_URL=redis://localhost:6379

# Development superadmin — set to your phone number to create a local
# superadmin account via `python seed_data.py`. Never commit a real number.
# Format: +91XXXXXXXXXX
DEV_SUPERADMIN_PHONE=+91XXXXXXXXXX

# MSG91 OTP (fill in Phase 1)
MSG91_API_KEY=your-msg91-key
MSG91_TEMPLATE_ID=your-template-id

# Twilio WhatsApp (fill in Phase 1)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AWS S3 Mumbai (PDFs)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=minerallaw-docs

# Razorpay (Phase 3)
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
